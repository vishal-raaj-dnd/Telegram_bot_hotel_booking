# ═══════════════════════════════════════════════════════════════════
# HotelBot SaaS — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/hotelbot

# ── Redis ────────────────────────────────────────────────────────────
# Format: redis://HOST:PORT or redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# ── Telegram Bot (Development — Single Bot) ──────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ── Stripe Payments ──────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys (use test keys for dev)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET_HERE
STRIPE_PROVIDER_TOKEN=YOUR_STRIPE_PROVIDER_TOKEN_FROM_BOTFATHER

# ── JWT Authentication ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_RANDOM_64_BYTE_HEX_SECRET_HERE

# ── AWS S3 (Room & Hotel Images) ─────────────────────────────────────
AWS_S3_BUCKET=YOUR_S3_BUCKET_NAME
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1

# ── Email (SendGrid) ─────────────────────────────────────────────────
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE

# ── Field-Level Encryption ───────────────────────────────────────────
# AES-256-GCM key — MUST be exactly 32 bytes (64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=YOUR_64_CHAR_HEX_ENCRYPTION_KEY_HERE

# ── Webhook Public URL (Production) ──────────────────────────────────
# The publicly accessible base URL of your backend server
# Example: https://api.yourdomain.com
WEBHOOK_BASE_URL=https://api.yourdomain.com

# ── Super Admin ──────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@yourdomain.com
# Generate hash with: node -e "const bcrypt = require('bcrypt'); bcrypt.hash('yourpassword', 12).then(console.log)"
SUPER_ADMIN_PASSWORD_HASH=YOUR_BCRYPT_HASHED_PASSWORD_HERE

# ── OpenAI (Phase 8 — AI NLP — Optional) ────────────────────────────
# Required only for Pro/Enterprise tier AI features
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
