// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
// TENANTS — Each hotel that subscribes to HotelBot SaaS
// ─────────────────────────────────────────────────────────────────
model Tenant {
  id                 String             @id @default(uuid())
  name               String
  telegramBotToken   String             @unique // AES-256 encrypted at app layer
  webhookUrl         String?
  subscriptionStatus SubscriptionStatus @default(trialing)
  stripeCustomerId   String?            @unique
  settings           Json               @default("{}")
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  tenantUsers    TenantUser[]
  tenantGuests   TenantGuest[]
  roomCategories RoomCategory[]
  bookings       Booking[]

  @@index([subscriptionStatus])
  @@map("tenants")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  suspended
}

// ─────────────────────────────────────────────────────────────────
// TENANT USERS — Hotel staff / owners with dashboard access
// ─────────────────────────────────────────────────────────────────
model TenantUser {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  role         StaffRole @default(staff)
  inviteToken  String?   @unique
  inviteExpiry DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([email])
  @@map("tenant_users")
}

enum StaffRole {
  owner
  manager
  staff
}

// ─────────────────────────────────────────────────────────────────
// GUESTS — Telegram users who have interacted with any hotel bot
// ─────────────────────────────────────────────────────────────────
model Guest {
  id                 String   @id @default(uuid())
  telegramId         BigInt   @unique
  firstName          String
  lastName           String?
  phoneNumber        String? // AES-256 encrypted at app layer
  languageCode       String?
  optInNotifications Boolean  @default(true)
  createdAt          DateTime @default(now())

  // Relations
  tenantGuests TenantGuest[]
  bookings     Booking[]

  @@index([telegramId])
  @@map("guests")
}

// ─────────────────────────────────────────────────────────────────
// TENANT GUESTS — Junction: which guests belong to which hotel
// ─────────────────────────────────────────────────────────────────
model TenantGuest {
  id        String   @id @default(uuid())
  tenantId  String
  guestId   String
  firstSeen DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guest  Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([tenantId, guestId])
  @@map("tenant_guests")
}

// ─────────────────────────────────────────────────────────────────
// ROOM CATEGORIES — Types of rooms a hotel offers
// ─────────────────────────────────────────────────────────────────
model RoomCategory {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  description    String
  pricePerNight  Decimal  @db.Decimal(10, 2)
  currency       String   @default("USD")
  maxGuests      Int
  totalInventory Int // total number of rooms of this type
  imageUrls      String[] @default([])
  amenities      String[] @default([])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([tenantId, isActive])
  @@map("room_categories")
}

// ─────────────────────────────────────────────────────────────────
// BOOKINGS — Core transaction record
// ─────────────────────────────────────────────────────────────────
model Booking {
  id                      String        @id @default(uuid())
  tenantId                String
  guestId                 String
  roomCategoryId          String
  bookingReference        String        @unique // e.g. GRD-2405-XK91
  checkIn                 DateTime      @db.Date
  checkOut                DateTime      @db.Date
  nightsCount             Int
  guestCount              Int
  totalAmountPaid         Decimal       @db.Decimal(10, 2)
  currency                String        @default("USD")
  status                  BookingStatus @default(pending)
  paymentIntentId         String?       @unique
  telegramPaymentChargeId String?       @unique
  receiptPdfUrl           String?
  reviewSentAt            DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  guest        Guest          @relation(fields: [guestId], references: [id])
  roomCategory RoomCategory   @relation(fields: [roomCategoryId], references: [id])
  events       BookingEvent[]

  @@index([tenantId, status])
  @@index([guestId])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
  refunded
}

// ─────────────────────────────────────────────────────────────────
// BOOKING EVENTS — Audit trail for every status change
// ─────────────────────────────────────────────────────────────────
model BookingEvent {
  id        String   @id @default(uuid())
  bookingId String
  event     String // e.g. "payment_received", "booking_cancelled"
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_events")
}
